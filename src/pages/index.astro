---
import Layout from "~/layouts/Layout.astro";
import Section from "~/components/Section.astro";
import Hero from "~/components/Hero.astro";
import { Picture, Image } from "astro:assets";
import Badge from "~/components/Badge.astro";
import Button from "~/components/Button.astro";
import ButtonCallUs from "~/components/ButtonCallUs.astro";
import Grid from "~/components/Grid.astro";
import Heading from "~/components/Heading.astro";
import WideImage from "~/components/WideImage.astro";
import ReviewSlider from "~/components/ReviewSlider.astro";

// Images
import PizzaHero from "~/assets/images/baleadas-hero.png";
import Pizza from "~/assets/images/yuca-chicharron.png";
import Spaghetti from "~/assets/images/sopa-caracol.png";
import Fish from "~/assets/images/baleada-especial.png";
import DecorativeImage from "~/assets/images/decorative-image.jpg";
import reviewAuthors from "~/assets/images/review-authors.jpg";
import Dessert from "~/assets/images/ayote-miel.png";
import Mussels from "~/assets/images/pollo-chuco.png";
import PlatoTipico from "~/assets/images/plato-tipico.png"
import Visitanos from "~/assets/images/visitanos.png"
---

<Layout title="Home" pageTitle="Home" description="Welcome to our restaurant!">
  <Section class:list={"bg-white"}>
    <Hero>
      <div slot="hero-content-left" class="prose max-w-none max-lg:order-1">
        <Badge title="El sabor hondureño de verdad" />
        <h1 class="font-black">Donde cada bocado cuenta una historia.</h1>

        <p>
          Bienvenido a Sabores del Valle, donde la cocina hondureña se sirve con
          orgullo y se come con alma. Cada platillo que sale de nuestra cocina
          lleva los mismos ingredientes, las mismas proporciones y el mismo
          cuidado de siempre.
        </p>

        <span class="text-brand-green font-medium"
          >✔ También hacemos entregas</span
        >

        <div class="mt-8 flex items-center gap-x-8">
          <Button url="/book">Reserva ahora</Button>
          <ButtonCallUs />
        </div>
      </div>
      <div slot="hero-content-right">
        <Picture
          class:list={"mx-auto"}
          src={PizzaHero}
          height={600}
          formats={["avif", "webp"]}
          alt="A description of my image."
          loading={"eager"}
          fetchpriority={"high"}
        />
      </div>
    </Hero>
  </Section>

  <section class="relative">
    <WideImage
      image={DecorativeImage}
      alt="Just an image"
      class:list={"aspect-video lg:aspect-16/6"}
    />

    <div
      class="absolute inset-0 bg-[#3B2A24]/70 flex flex-col items-center justify-center px-4 sm:px-6"
    >
      <h2 class="font-black text-white! text-2xl sm:text-4xl mb-2 text-center">
        Horarios de atención
      </h2>
      <p
        class="text-[#D8B98A] font-medium mb-6 sm:mb-10 text-center text-sm sm:text-base"
      >
        Siempre listos para recibirte
      </p>

      <div class="flex flex-col sm:flex-row gap-3 w-full max-w-3xl">
        <div
          class="flex-1 bg-white/10 backdrop-blur-sm rounded-xl px-4 sm:px-10 py-5 sm:py-7 flex justify-between items-center"
        >
          <h3 class="text-white! font-bold text-sm sm:text-lg">
            Lunes a Sábado
          </h3>
          <p class="text-lg sm:text-2xl font-black text-[#D8B98A]">
            07:00 — 21:00
          </p>
        </div>

        <div
          class="flex-1 bg-white/10 backdrop-blur-sm rounded-xl px-4 sm:px-10 py-5 sm:py-7 flex justify-between items-center"
        >
          <h3 class="text-white! font-bold text-sm sm:text-lg">Domingo</h3>
          <p class="text-lg sm:text-2xl font-black text-[#D8B98A]">
            08:00 — 15:00
          </p>
        </div>
      </div>
    </div>
  </section>

  <Section class:list={"bg-white"}>
    <Heading>
      <h2 slot="heading-title" class="font-black text-brand-green h2">
        Nuestros platillos
      </h2>
      <p slot="heading-content">
        Explora nuestra selección de platillos hondureños, desde baleadas y
        pastelitos hasta sopa de caracol y pollo chuco.
      </p>
    </Heading>

    <Grid>
      <div slot="grid-content-1">
        <div class="flex flex-col items-center prose text-center">
          <Picture
            class:list={"not-prose w-full h-auto"}
            src={Pizza}
            formats={["avif", "webp"]}
            alt="A description of my image."
          />
          <h3 class="h4 mt-0 font-black">Yuca con Chicharrón</h3>
          <p>
            La yuca con chicharrón es uno de esos platos que no necesitan
            presentación. Yuca cocida y frita hasta quedar dorada por fuera y
            suave por dentro, acompañada de chicharrón crujiente, curtido fresco
            de repollo y un buen chimol casero.
          </p>
        </div>
      </div>

      <div slot="grid-content-2">
        <div class="flex flex-col items-center prose text-center">
          <Picture
            class:list={"not-prose w-full h-auto"}
            src={Spaghetti}
            formats={["avif", "webp"]}
            alt="A description of my image."
          />
          <h3 class="h4 mt-0 font-black">Sopa de Caracol</h3>
          <p>
            Un clásico de la costa hondureña que conquistó todo el país. Nuestra
            sopa de caracol se prepara con leche de coco, yuca, plátano y
            especias que llevan horas a fuego lento.
          </p>
        </div>
      </div>

      <div slot="grid-content-3">
        <div class="flex flex-col items-center prose text-center">
          <Picture
            class:list={"not-prose w-full h-auto"}
            src={Fish}
            formats={["avif", "webp"]}
            alt="A description of my image."
          />
          <h3 class="h4 mt-0 font-black">Baleada Especial</h3>
          <p>
            La reina de la cocina hondureña. Una tortilla de harina suave y
            recién hecha, rellena de frijoles refritos, mantequilla, queso
            rallado, crema y huevo.
          </p>
        </div>
      </div>
    </Grid>
  </Section>

  <Section class:list={"bg-white"}>
    <Hero>
      <div slot="hero-content-left" class="prose lg:order-2">
        <h1 class="font-black">Almuerzo Típico</h1>

        <p>
          El almuerzo típico hondureño es más que un plato, es una costumbre.
          Una mesa completa que reúne todo lo que necesitas: carne asada o
          frita, frijoles rojos cocidos a fuego lento, arroz blanco, queso seco
          rallado, mantequilla, plátanos fritos y un buen chimol hecho en casa.
          Nada sobra, nada falta.
        </p>

        <p>
          En Sabores del Valle lo servimos como se debe, con los mismos
          ingredientes y la misma generosidad de siempre. Porque el almuerzo
          típico no es solo comida, es el plato que te recuerda a tu casa, a tu
          familia y a Honduras.
        </p>

        <div class="mt-8">
          <Button url="/menu">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 20 20"
              fill="currentColor"
              class="size-5 inline-block"
              aria-hidden="true"
            >
              <path
                fill-rule="evenodd"
                d="M8.22 5.22a.75.75 0 0 1 1.06 0l4.25 4.25a.75.75 0 0 1 0 1.06l-4.25 4.25a.75.75 0 0 1-1.06-1.06L11.94 10 8.22 6.28a.75.75 0 0 1 0-1.06Z"
                clip-rule="evenodd"></path>
            </svg>
            Ver menú
          </Button>
        </div>
      </div>
      <div slot="hero-content-right">
        <Picture
          class:list={"mx-auto"}
          src={PlatoTipico}
          height={600}
          formats={["avif", "webp"]}
          alt="A description of my image."
        />
      </div>
    </Hero>
  </Section>

  <Section class:list={"bg-white"}>
    <Hero>
      <div slot="hero-content-left" class="prose max-w-none max-lg:order-1">
        <Badge color="red" title="Delicioso" />
        <h2 class="font-black h2 my-4!">Plato de la semana</h2>

        <span class="text-brand-red text-2xl font-bold italic">
          Pollo Chuco
        </span>

        <p>
          El plato de esta semana es uno de los favoritos de nuestra cocina.
          Pollo chuco: piezas de pollo frito y crujiente servidas sobre tajadas
          de plátano, acompañadas de encurtido, chimol fresco y aderezo de
          mayonesa. Un plato contundente, lleno de sabor y completamente
          hondureño. Disponible solo esta semana, no te lo pierdas.
        </p>

        <div class="mt-8">
          <Button color="red" url="/book">Reserva ahora</Button>
        </div>
      </div>
      <div slot="hero-content-right">
        <Picture
          class:list={"mx-auto"}
          src={Mussels}
          height={600}
          formats={["avif", "webp"]}
          alt="A description of my image."
        />
      </div>
    </Hero>
  </Section>

  <!-- Reviews -->
  <Section class:list={"bg-brand-red/20 relative"}>
    <div class="py-16">
      <Hero>
        <div slot="hero-content-left" class="prose max-w-none order-2">
          <div class="text-center not-prose">
            <Badge color="white" title="Reseñas" />
          </div>
          <h2 slot="heading-title" class="font-black h4 text-center mt-0 mb-4">
            Lo que dicen nuestros clientes...
          </h2>
          <div slot="heading-content">
            <p class="text-center">
              No tienes que creerle solo a nuestra palabra. Esto es lo que dicen
              quienes ya se sentaron en nuestra mesa y vivieron la experiencia.
            </p>
            <ReviewSlider />
          </div>
        </div>

        <div slot="hero-content-right">
          <Picture
            src={reviewAuthors}
            alt="Review authors"
            class="w-full h-auto rounded-lg"
          />
        </div>
      </Hero>
    </div>

    <svg
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 1440 320"
      class="absolute h-40 w-full top-0 inset-x-0 rotate-180"
      preserveAspectRatio="none"
      ><path
        fill="#ffffff"
        fill-opacity="1"
        d="M0,288L48,272C96,256,192,224,288,197.3C384,171,480,149,576,165.3C672,181,768,235,864,250.7C960,267,1056,245,1152,250.7C1248,256,1344,288,1392,304L1440,320L1440,320L1392,320C1344,320,1248,320,1152,320C1056,320,960,320,864,320C768,320,672,320,576,320C480,320,384,320,288,320C192,320,96,320,48,320L0,320Z"
      ></path>
    </svg>
    <svg
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 1440 320"
      class="absolute h-40 w-full bottom-0 inset-x-0"
      preserveAspectRatio="none"
      ><path
        fill="#ffffff"
        fill-opacity="1"
        d="M0,288L48,272C96,256,192,224,288,197.3C384,171,480,149,576,165.3C672,181,768,235,864,250.7C960,267,1056,245,1152,250.7C1248,256,1344,288,1392,304L1440,320L1440,320L1392,320C1344,320,1248,320,1152,320C1056,320,960,320,864,320C768,320,672,320,576,320C480,320,384,320,288,320C192,320,96,320,48,320L0,320Z"
      ></path>
    </svg>
  </Section>

  <!-- Desserts -->
  <Section class:list={"bg-white"}>
    <Hero>
      <div slot="hero-content-left" class="prose max-w-none order-2">
        <Badge title="Dulces" />
        <h2 slot="heading-title" class="font-black text-brand-green h2 my-4!">
          Postres
        </h2>
        <div slot="heading-content">
          <p>
            Termina tu visita con algo dulce. Nuestros postres son caseros,
            elaborados con ingredientes frescos y recetas que llevan años
            perfeccionándose en nuestra cocina. El final perfecto para una buena
            comida.
          </p>

          <p>
            Desde dulces tradicionales hondureños hasta opciones más
            indulgentes, nuestra selección de postres tiene algo para cada
            gusto. Porque una buena mesa no está completa sin un buen cierre.
          </p>
          <div class="mt-8">
            <Button url="/menu">Ve nuestro menú</Button>
          </div>
        </div>
      </div>

      <div slot="hero-content-right">
        <Picture
          class:list={"mx-auto"}
          src={Dessert}
          height={600}
          formats={["avif", "webp"]}
          alt="A description of my image."
        />
      </div>
    </Hero>
  </Section>

  <!-- Contact -->
  <Section class:list={"bg-white"}>
    <Hero>
      <div slot="hero-content-left" class="prose max-w-none">
        <Badge color="red" title="Bienvenido" />
        <h2 slot="heading-title" class="font-black text-brand-red h2 my-4!">
          ¡Pasa por aquí!
        </h2>
        <div slot="heading-content">
          <p>
            Estamos en la Colonia Palmira, en el corazón de Tegucigalpa. Un
            lugar fácil de llegar y difícil de olvidar. Ya sea para almorzar,
            desayunar o simplemente antojarte de algo rico, aquí siempre hay un
            plato esperándote.
          </p>

          <span class="text-brand-red font-medium">
            ✔ También hacemos para llevar, porque el sabor de Sabores del Valle
            te puede acompañar hasta tu casa
          </span>
          <div class="mt-8">
            <Button color="red" url="/book">Reserva una mesa</Button>
          </div>
        </div>
      </div>

      <div slot="hero-content-right">
        <Picture
          class:list={"mx-auto"}
          src={Visitanos}
          height={600}
          formats={["avif", "webp"]}
          alt="A description of my image."
        />
      </div>
    </Hero>
  </Section>
</Layout>
